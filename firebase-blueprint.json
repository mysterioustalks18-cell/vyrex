{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core user data and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "niche": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ContentAsset": {
      "title": "Generated Content Asset",
      "description": "Ideas, scripts, and strategy pieces generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "type": { "type": "string", "enum": ["idea", "script", "thumbnail", "strategy"] },
        "content": { "type": "object" },
        "feedback": { "type": "string", "enum": ["good", "bad", "none"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "type", "content", "timestamp"]
    },
    "Interaction": {
      "title": "Node Interaction",
      "description": "Record of a node execution",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "node": { "type": "string" },
        "prompt": { "type": "string" },
        "result": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "node", "prompt", "result", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Authenticated user profiles"
    },
    "/users/{userId}/assets/{assetId}": {
      "schema": "ContentAsset",
      "description": "User-specific generated content assets"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Global log of node executions"
    }
  }
}
